#!/usr/bin/env node
// Copyright (c) 2026 Marius Kamm. MIT.
// mc-kit — CLI entry point. Dispatches subcommands to lib/*.

'use strict';

const fs   = require('fs');
const path = require('path');
const os   = require('os');

const pkgRoot = path.resolve(__dirname, '..');
const { loadConfig, DEFAULTS } = require(path.join(pkgRoot, 'lib', 'config'));

const USAGE = `mc-kit — Mission Control integration toolkit

Usage: mc-kit <command> [args...]

Project setup:
  init                           Create .mc-kit.json in current directory (prompts)
  doctor                         Check MC reachable, .env present, API_KEY valid
  doctor --fix-onboarding        Register stub agent so the Launch Sequence card hides
  doctor --fix-onboarding --include-banner
                                 Also set NEXT_PUBLIC_GATEWAY_OPTIONAL=true (requires restart)

Sync backlog <-> MC:
  sync push [--dry]              Push docs/BACKLOG.md items to MC Kanban
  sync pull [--dry]              Pull "done" status from MC back to BACKLOG.md

Live task operations (orchestrator helpers):
  list [--status S] [--json]     List tasks (filter by status)
  get <id>                       Task details (id = #B<NN> | PANO-NN | raw)
  status <id> <new-status>       Set status (inbox|assigned|in_progress|review|quality_review|done)
  comment <id> "text"            Post comment
  open-count                     Print integer: how many tasks not-done
  next-task [--theme T] [--priority P] [--json]
                                 Pick highest-priority open task (for orchestrator dispatch)
  open <id>                      Open task card in the browser
  assign <id> "Agent Name"       Assign task to agent (CLI escape hatch; MC UI has a bug)
  unassign <id>                  Unassign task (sends assigned_to="", MC UI sends null → 400)
  watch-dispatch [--assigned-to NAME] [--tag T] [--interval S] [--once] [--json]
                                 Poll MC for tasks assigned to "Claude Code (external)" (default)
                                 OR tagged 'claude-dispatch' — first match wins, assignment preferred

Mission Control lifecycle:
  ide                            Start MC container (idempotent), open dashboard
  ide:start                      Alias for 'ide'
  ide:stop                       Stop MC container
  ide:status                     Show container status
  ide:logs                       Tail container logs

Optional features:
  screenshot <xml> <tab> <out>   Headless Playwright capture (needs cfg.bundle_path)

Global flags:
  -v, --verbose                  Dump HTTP requests/responses to stderr

Env overrides:
  MC_BASE       default: ${DEFAULTS.mc_base}
  MC_ENV_FILE   default: ${DEFAULTS.mc_env_file}

Config: .mc-kit.json in project root. See 'mc-kit init' to scaffold.
`;

function readLine(prompt) {
  return new Promise(resolve => {
    const rl = require('readline').createInterface({ input: process.stdin, output: process.stdout });
    rl.question(prompt, ans => { rl.close(); resolve(ans.trim()); });
  });
}

async function cmdInit() {
  const cwd = process.cwd();
  const target = path.join(cwd, '.mc-kit.json');
  if (fs.existsSync(target)) {
    const yn = await readLine('.mc-kit.json already exists — overwrite? [y/N] ');
    if (yn.toLowerCase() !== 'y') return console.log('Aborted.');
  }
  const name = await readLine('Project name (e.g. "My App"): ');
  const backlog = await readLine('Backlog path [docs/BACKLOG.md]: ') || 'docs/BACKLOG.md';
  const bundle = await readLine('Optional bundle for screenshots (HTML file) []: ');

  const cfg = {
    project_name: name,
    project_desc: '',
    backlog_path: backlog,
    id_prefix: 'B',
    themes: ['AUDIT', 'PARITY', 'UX', 'PERF', 'TRUST'],
  };
  if (bundle) cfg.bundle_path = bundle;

  fs.writeFileSync(target, JSON.stringify(cfg, null, 2) + '\n');
  console.log('✓ Wrote .mc-kit.json');

  const backlogAbs = path.join(cwd, backlog);
  if (!fs.existsSync(backlogAbs)) {
    const stub = fs.readFileSync(path.join(pkgRoot, 'templates', 'backlog-stub.md'), 'utf8');
    fs.mkdirSync(path.dirname(backlogAbs), { recursive: true });
    fs.writeFileSync(backlogAbs, stub.replace(/{{PROJECT_NAME}}/g, name));
    console.log('✓ Created backlog stub at ' + backlog);
  }

  console.log('\nNext steps:');
  console.log('  1. mc-kit doctor           # verify MC is reachable');
  console.log('  2. mc-kit sync push        # push backlog to Kanban');
  console.log('  3. mc-kit ide              # open dashboard');
}

async function cmdDoctor(args) {
  args = args || [];
  const cfg = loadConfig();
  const { readApiKey } = require(path.join(pkgRoot, 'lib', 'config'));
  const { request } = require(path.join(pkgRoot, 'lib', 'client'));
  const doctor = require(path.join(pkgRoot, 'lib', 'doctor'));

  if (args.includes('--fix-onboarding')) {
    return doctor.fixOnboarding(cfg, { includeBanner: args.includes('--include-banner') });
  }

  console.log('Project root: ' + cfg._root);
  console.log('Project name: ' + cfg.project_name);
  console.log('Backlog:      ' + cfg.backlog_path + '  ' + (fs.existsSync(cfg.backlog_path) ? '✓' : '✗ missing'));
  console.log('MC base:      ' + cfg.mc_base);
  console.log('MC .env:      ' + cfg.mc_env_file);
  try { readApiKey(cfg); console.log('API key:      ✓ present'); }
  catch (e) { console.log('API key:      ✗ ' + e.message); return process.exit(1); }
  try {
    const r = await request(cfg, 'GET', '/api/projects');
    console.log('MC API:       ✓ reachable (' + r.status + ')');
  } catch (e) {
    console.log('MC API:       ✗ ' + e.message);
    console.log('\nIs the container running? Try: mc-kit ide');
    process.exit(1);
  }

  const st = await doctor.onboardingStatus(cfg);
  const agentsCell = st.agents == null ? '?' : (st.agents > 0 ? '✓ ' + st.agents + ' registered' : '✗ none');
  const skippedCell = st.skipped == null ? '?' : (st.skipped ? '✓ skipped (api user)' : '✗ not skipped');
  const gatewayCell = st.gatewayOptional == null ? '?' : (st.gatewayOptional ? '✓ optional' : '✗ required');
  console.log('Agents:       ' + agentsCell);
  console.log('Onboarding:   ' + skippedCell);
  console.log('Gateway:      ' + gatewayCell);
  const launchSeqFix = (st.agents !== null && st.agents === 0) || st.skipped === false;
  const gatewayFix = st.gatewayOptional === false;
  if (launchSeqFix && gatewayFix) {
    console.log('\nLaunch Sequence card + "No gateway" banner still visible.');
    console.log('Run: mc-kit doctor --fix-onboarding --include-banner');
  } else if (launchSeqFix) {
    console.log('\nLaunch Sequence card still visible.');
    console.log('Run: mc-kit doctor --fix-onboarding');
  } else if (gatewayFix) {
    console.log('\n"No gateway detected" banner still visible (needs .env change).');
    console.log('Run: mc-kit doctor --fix-onboarding --include-banner');
  }
}

async function cmdSync(args) {
  const cfg = loadConfig();
  const { push, pull } = require(path.join(pkgRoot, 'lib', 'sync'));
  const dry = args.includes('--dry') || args.includes('--dry-run');
  const mode = args[0] || 'push';
  if (mode === 'push') return void (await push(cfg, { dry }));
  if (mode === 'pull') return void (await pull(cfg, { dry }));
  throw new Error('sync mode: push | pull');
}

async function cmdList(args) {
  const cfg = loadConfig();
  const { listTasks } = require(path.join(pkgRoot, 'lib', 'client'));
  const statusIdx = args.indexOf('--status');
  const filter = {};
  if (statusIdx >= 0) filter.status = args[statusIdx + 1];
  const tasks = await listTasks(cfg, filter);
  if (args.includes('--json')) return console.log(JSON.stringify(tasks, null, 2));
  console.log('Total: ' + tasks.length);
  tasks.forEach(t => {
    const tags = (t.tags || []).find(x => x.startsWith('#' + cfg.id_prefix)) || '';
    console.log(`  ${(t.ticket_ref || '?').padEnd(10)} ${tags.padEnd(8)} [${(t.priority || '?').padEnd(6)}] ${(t.status || '?').padEnd(14)} ${(t.title || '').slice(0, 70)}`);
  });
}

async function cmdGet(args) {
  const cfg = loadConfig();
  const { getTask } = require(path.join(pkgRoot, 'lib', 'client'));
  const t = await getTask(cfg, args[0]);
  if (args.includes('--json')) return console.log(JSON.stringify(t, null, 2));
  console.log('---');
  console.log('ID:         ' + t.id + '  (' + t.ticket_ref + ')');
  console.log('Title:      ' + t.title);
  console.log('Status:     ' + t.status + '  (priority: ' + t.priority + ')');
  console.log('Tags:       ' + (t.tags || []).join(', '));
  if (t.description) { console.log('---'); console.log(t.description); }
}

async function cmdStatus(args) {
  const cfg = loadConfig();
  const { setStatus } = require(path.join(pkgRoot, 'lib', 'client'));
  const res = await setStatus(cfg, args[0], args[1]);
  console.log('✓ Task ' + res.id + ' → ' + res.status);
}

async function cmdComment(args) {
  const cfg = loadConfig();
  const { comment } = require(path.join(pkgRoot, 'lib', 'client'));
  const res = await comment(cfg, args[0], args.slice(1).join(' '));
  console.log('✓ Comment added to task ' + res.id);
}

async function cmdOpenCount() {
  const cfg = loadConfig();
  const { openCount } = require(path.join(pkgRoot, 'lib', 'client'));
  console.log(await openCount(cfg));
}

const STATUS_PRIORITY = { in_progress: 0, assigned: 1, inbox: 2, review: 3, quality_review: 4, done: 99 };
const PRIORITY_RANK   = { high: 0, medium: 1, low: 2 };

async function cmdNextTask(args) {
  const cfg = loadConfig();
  const { listTasks } = require(path.join(pkgRoot, 'lib', 'client'));
  const themeIdx = args.indexOf('--theme');
  const prioIdx = args.indexOf('--priority');
  const theme = themeIdx >= 0 ? args[themeIdx + 1] : null;
  const priorityFilter = prioIdx >= 0 ? args[prioIdx + 1] : null;

  const all = await listTasks(cfg, {});
  let candidates = all.filter(t => t.status !== 'done');
  if (theme) {
    const wanted = theme.toUpperCase();
    candidates = candidates.filter(t => (t.tags || []).some(tag => tag.toUpperCase() === wanted));
  }
  if (priorityFilter) {
    candidates = candidates.filter(t => (t.priority || 'medium') === priorityFilter);
  }
  candidates.sort((a, b) => {
    const sa = STATUS_PRIORITY[a.status] ?? 50;
    const sb = STATUS_PRIORITY[b.status] ?? 50;
    if (sa !== sb) return sa - sb;
    const pa = PRIORITY_RANK[a.priority || 'medium'] ?? 1;
    const pb = PRIORITY_RANK[b.priority || 'medium'] ?? 1;
    if (pa !== pb) return pa - pb;
    return (a.id || 0) - (b.id || 0);
  });
  const top = candidates[0];
  if (!top) {
    console.error('No open tasks match.');
    process.exit(1);
  }
  if (args.includes('--json')) return console.log(JSON.stringify(top, null, 2));
  const backlogId = (top.tags || []).find(x => x.startsWith('#' + cfg.id_prefix)) || '';
  const themeTag = (top.tags || []).find(x => cfg.themes.includes(x.toUpperCase())) || '';
  console.log('Next task: ' + (top.ticket_ref || '?') + '  ' + backlogId + '  [' + themeTag + '/' + (top.priority || '?') + '/' + top.status + ']');
  console.log('  Title: ' + (top.title || ''));
  if (top.description) {
    const first = top.description.split(/\r?\n/)[0].slice(0, 160);
    console.log('  ' + first);
  }
  console.log('  Run: /pa-work ' + (backlogId || top.ticket_ref));
}

async function cmdOpen(args) {
  const cfg = loadConfig();
  const { resolveTaskId } = require(path.join(pkgRoot, 'lib', 'client'));
  if (!args[0]) throw new Error('Usage: mc-kit open <task-id>');
  const id = await resolveTaskId(cfg, args[0]);
  const url = cfg.mc_base + '/tasks?taskId=' + id;
  console.log('Opening ' + url);
  const opener = process.platform === 'darwin' ? 'open' : (process.platform === 'win32' ? 'start' : 'xdg-open');
  const { spawn } = require('child_process');
  spawn(opener, [url], { detached: true, stdio: 'ignore' }).unref();
}

async function cmdAssign(args) {
  const cfg = loadConfig();
  const { resolveTaskId, request } = require(path.join(pkgRoot, 'lib', 'client'));
  if (!args[0]) throw new Error('Usage: mc-kit assign <task-id> <agent-name | "">  (empty string unassigns)');
  const id = await resolveTaskId(cfg, args[0]);
  const newAssignee = args.slice(1).join(' ');
  const res = await request(cfg, 'PUT', '/api/tasks/' + id, { assigned_to: newAssignee });
  if (res.status >= 400) throw new Error('PUT failed: ' + res.status + ' ' + JSON.stringify(res.data));
  const t = (res.data && res.data.task) || res.data;
  console.log('✓ Task ' + id + ' → assigned_to=' + JSON.stringify(t.assigned_to || ''));
}

async function cmdUnassign(args) {
  return cmdAssign([args[0], '']);
}

async function cmdWatchDispatch(args) {
  const cfg = loadConfig();
  const { pollDispatched, notify, DEFAULT_TAG, DEFAULT_ASSIGNEE } = require(path.join(pkgRoot, 'lib', 'dispatch'));
  const tagIdx = args.indexOf('--tag');
  const assignIdx = args.indexOf('--assigned-to');
  const intIdx = args.indexOf('--interval');
  const tag = tagIdx >= 0 ? args[tagIdx + 1] : DEFAULT_TAG;
  const assignedTo = assignIdx >= 0 ? args[assignIdx + 1] : DEFAULT_ASSIGNEE;
  const interval = intIdx >= 0 ? Math.max(5, parseInt(args[intIdx + 1], 10) || 60) : 60;
  const once = args.includes('--once');
  const json = args.includes('--json');

  const formatTop = (top) => {
    const backlogId = (top.tags || []).find(x => String(x).startsWith('#' + cfg.id_prefix)) || '';
    return { backlogId, ref: top.ticket_ref || String(top.id || '') };
  };

  while (true) {
    let dispatched = [];
    try {
      dispatched = await pollDispatched(cfg, { tag, assignedTo });
    } catch (e) {
      process.stderr.write('[watch-dispatch] poll error: ' + e.message + '\n');
      if (once) process.exit(2);
    }
    if (dispatched.length > 0) {
      const top = dispatched[0];
      const f = formatTop(top);
      if (json) {
        console.log(JSON.stringify(top));
      } else {
        console.log('Dispatched: ' + f.ref + (f.backlogId ? '  ' + f.backlogId : '') +
          '  [' + (top.priority || '?') + '/' + top.status + ']');
        console.log('  ' + (top.title || ''));
        console.log('  → /pa-work ' + (f.backlogId || f.ref));
      }
      notify('mc-kit: new task for Claude',
             (f.backlogId || f.ref) + ': ' + (top.title || '').slice(0, 100));
      if (once) process.exit(0);
      process.stderr.write('[watch-dispatch] dispatched — continuing poll in ' + interval + 's\n');
    } else if (once) {
      process.exit(1);
    } else {
      process.stderr.write('[watch-dispatch] no tasks assigned to "' + assignedTo + '" or tagged "' + tag + '"; next poll in ' + interval + 's\n');
    }
    if (once) return;
    await new Promise(r => setTimeout(r, interval * 1000));
  }
}

async function cmdIde(args) {
  const cfg = loadConfig({ optional: true });
  const script = path.join(pkgRoot, 'scripts', 'ide.sh');
  const { spawn } = require('child_process');
  const sub = args[0] || 'start';
  const child = spawn('bash', [script, sub], {
    stdio: 'inherit',
    env: { ...process.env, MC_DIR: cfg.mc_dir, MC_URL: cfg.mc_base, MC_KIT_PROJECT_ROOT: cfg._root || process.cwd() },
  });
  await new Promise(r => child.on('close', r));
}

async function cmdScreenshot(args) {
  const cfg = loadConfig();
  const { capture } = require(path.join(pkgRoot, 'lib', 'screenshot'));
  const out = await capture(cfg, args);
  console.log('Wrote ' + out);
}

const CMDS = {
  'init':         cmdInit,
  'doctor':       cmdDoctor,
  'sync':         cmdSync,
  'list':         cmdList,
  'get':          cmdGet,
  'status':       cmdStatus,
  'comment':      cmdComment,
  'open-count':   cmdOpenCount,
  'next-task':    cmdNextTask,
  'open':         cmdOpen,
  'assign':       cmdAssign,
  'unassign':     cmdUnassign,
  'watch-dispatch': cmdWatchDispatch,
  'ide':          (a) => cmdIde(['start', ...a]),
  'ide:start':    (a) => cmdIde(['start', ...a]),
  'ide:stop':     () => cmdIde(['stop']),
  'ide:status':   () => cmdIde(['status']),
  'ide:logs':     () => cmdIde(['logs']),
  'screenshot':   cmdScreenshot,
};

async function main() {
  const argv = process.argv.slice(2).filter(a => {
    if (a === '-v' || a === '--verbose') { process.env.MC_KIT_VERBOSE = '1'; return false; }
    return true;
  });
  const [cmd, ...args] = argv;
  if (!cmd || cmd === '--help' || cmd === '-h') return console.log(USAGE);
  const fn = CMDS[cmd];
  if (!fn) { console.error('Unknown command: ' + cmd + '\n\n' + USAGE); process.exit(1); }
  try { await fn(args); }
  catch (e) {
    console.error('ERROR: ' + e.message);
    if (/ECONNREFUSED/.test(e.message)) console.error('MC not running — try: mc-kit ide');
    process.exit(1);
  }
}
main();
